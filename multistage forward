#include <stdio.h>
#define INF 9999

int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int cost[n][n], dist[n];

    printf("Enter cost adjacency matrix (use 9999 for no edge):\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
        }
    }

  
    for (int i = 0; i < n; i++)
        dist[i] = INF;

    dist[0] = 0;

    
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (cost[i][j] != INF && dist[i] + cost[i][j] < dist[j]) {
                dist[j] = dist[i] + cost[i][j];
            }
        }
    }

  
    printf("Minimum cost = %d\n", dist[n-1]);

    return 0;
}
