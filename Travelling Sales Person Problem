#include <stdio.h>
#include <limits.h>

#define MAX 10

int n;
int graph[MAX][MAX];
int visited[MAX];
int minCost = INT_MAX;
void tsp(int city, int count, int cost, int start) {
    if (count == n && graph[city][start]) {
        cost += graph[city][start];
        if (cost < minCost) {
            minCost = cost;
        }
        return;
    }

    for (int i = 0; i < n; i++) {
        if (!visited[i] && graph[city][i]) {
            visited[i] = 1;
            tsp(i, count + 1, cost + graph[city][i], start);
            visited[i] = 0;
        }
    }
}

int main() {
    printf("Enter number of cities: ");
    scanf("%d", &n);

    printf("Enter cost matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }
    for (int i = 0; i < n; i++)
        visited[i] = 0;

    visited[0] = 1;
    tsp(0, 1, 0, 0);

    printf("Minimum Travelling Cost = %d\n", minCost);

    return 0;
}
