#include <stdio.h>
#define INF 9999

int main() {
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int cost[n][n], dist[n], path[n];

    printf("Enter cost adjacency matrix (use 9999 for no edge):\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
        }
    }

  
    dist[n-1] = 0;

  
    for (int i = n - 2; i >= 0; i--) {
        dist[i] = INF;
        for (int j = i + 1; j < n; j++) {
            if (cost[i][j] != INF && cost[i][j] + dist[j] < dist[i]) {
                dist[i] = cost[i][j] + dist[j];
                path[i] = j;
            }
        }
    }

    
    printf("Minimum cost = %d\n", dist[0]);

  
    printf("Path: ");
    int i = 0;
    while (i < n - 1) {
        printf("%d -> ", i);
        i = path[i];
    }
    printf("%d\n", n - 1);

    return 0;
}
